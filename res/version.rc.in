#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @MIC_TOGGLE_VERSION_MAJOR@,@MIC_TOGGLE_VERSION_MINOR@,@MIC_TOGGLE_VERSION_PATCH@,@MIC_TOGGLE_VERSION_BUILD@
 PRODUCTVERSION @MIC_TOGGLE_VERSION_MAJOR@,@MIC_TOGGLE_VERSION_MINOR@,@MIC_TOGGLE_VERSION_PATCH@,@MIC_TOGGLE_VERSION_BUILD@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "FileDescription", "MicToggle microphone mute utility\0"
      VALUE "FileVersion", "@MIC_TOGGLE_VERSION_NORMALIZED@\0"
      VALUE "InternalName", "MicToggle\0"
      VALUE "OriginalFilename", "MicToggle.exe\0"
      VALUE "ProductName", "MicToggle\0"
      VALUE "ProductVersion", "@MIC_TOGGLE_VERSION_NORMALIZED@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
